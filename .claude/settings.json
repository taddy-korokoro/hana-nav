{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/format-and-lint.sh",
            "timeout": 60,
            "statusMessage": "Formatting & linting changed file..."
          }
        ]
      }
    ]
  }
}
