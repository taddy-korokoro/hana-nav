# hana nav 環境変数テンプレート
#
# 環境は 2 つだけ運用する（MVP 方針）：
#   - ローカル開発: このファイルを `.env.local` にコピーして値を埋める。
#   - 本番（Vercel）: Vercel Dashboard > Project Settings > Environment Variables に
#     **Production にのみ** 登録する（Preview / Development はチェックを外す）。
# 詳細な登録手順は `docs/launch-runbook.md` を参照。

# --- Supabase ---
# Public（Client Component から参照可）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server 専用。Route Handler / Server Action / バッチに閉じる。
# 絶対に NEXT_PUBLIC_ プレフィックスを付けない。Client Component から import しない。
SUPABASE_SERVICE_ROLE_KEY=

# --- Google APIs ---
# Server 専用。Route Handler 内で使用。
GEMINI_API_KEY=

# Client 公開。Google Cloud Console で本番 URL に HTTP リファラー制限をかける。
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- 楽天ウェブサービス / 楽天アフィリエイト ---
# Server 専用。Server Component / Route Handler / Server Action 以外から参照しない。
# 未設定（Application ID または Access Key のどちらか）の場合はアフィリエイト枠は
# 静かに非表示になる（ページ全体は壊れない）。
#
# 2026-05-14 楽天ウェブサービス API 移行で `accessKey` が必須化された。
# 旧 `applicationId` のみでの呼び出しは 400 (specify valid applicationId) で拒否される。
#
# 取得手順:
#   1. https://webservice.rakuten.co.jp/app/list でアプリ詳細を開く
#   2. 「アプリケーション ID」と「アクセスキー」をそれぞれコピー
#   3. https://affiliate.rakuten.co.jp/ で Affiliate ID を確認
RAKUTEN_APPLICATION_ID=
RAKUTEN_ACCESS_KEY=
RAKUTEN_AFFILIATE_ID=

# --- お問い合わせフォーム（SMTP / Gmail） ---
# Server 専用。Server Action 内で nodemailer 経由で運用宛通知メールを送る。
# Supabase の Custom SMTP に使っている Gmail SMTP（hananav.noreply@gmail.com + アプリパスワード）を
# そのまま使い回す。アプリパスワードの取得手順は docs/launch-runbook.md の「Custom SMTP」節を参照。
# 未設定でも /contact フォームは動作する（DB 保存はされる）が通知メールは送られない。
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hananav.noreply@gmail.com
SMTP_PASS=
# お問い合わせ通知の宛先（運用 Gmail）
CONTACT_NOTIFICATION_TO=hananav.noreply@gmail.com

# --- Site ---
# 本番 URL は独自ドメイン https://hananav.site（ムームードメイン + ムームー DNS で運用）。
# sitemap / robots / OGP の絶対 URL / Auth リダイレクトで参照する。
# ローカル開発時は http://localhost:3000 のまま。
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- タイムゾーンについて ---
# `TZ` は Vercel の予約環境変数（AWS Lambda 由来）で、Production に登録できない。
# 本番ランタイムは UTC 固定で動くため、JST が必要な処理は `lib/utils/dateUtils.ts`
# のヘルパー（tokyoMonth / tokyoYmd / tokyoTodayStartIso / tokyoMonthStartIso）を使う。
# ローカル開発でもこのファイルに TZ は設定しない（実環境とズレないため）。
