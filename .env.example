# hana nav 環境変数テンプレート
#
# - ローカル開発: このファイルを `.env.local` にコピーして値を埋める。
# - 本番（Vercel）: Vercel Dashboard > Project Settings > Environment Variables に
#   Production / Preview / Development それぞれ登録する（`.env.production` は
#   リポジトリにコミットしない）。
# - 詳細な登録手順は `docs/launch-runbook.md` を参照。

# --- Supabase ---
# Public（Client Component から参照可）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server 専用。Route Handler / Server Action / バッチに閉じる。
# 絶対に NEXT_PUBLIC_ プレフィックスを付けない。Client Component から import しない。
SUPABASE_SERVICE_ROLE_KEY=

# --- Google APIs ---
# Server 専用。Route Handler 内で使用。
GEMINI_API_KEY=

# Client 公開。Google Cloud Console で本番ドメインに HTTP リファラー制限をかける。
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Site ---
# 本番では https://hana-nav.jp 等の本番 URL に切り替える。
# sitemap / robots / 絶対 URL 生成 / Auth リダイレクトで参照する。
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Runtime ---
# Node.js ランタイムのタイムゾーン。AI 利用回数の「今日」判定や日付ログを JST に揃える。
# Vercel でも同名で登録すること。
TZ=Asia/Tokyo
